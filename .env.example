# Gemini API Configuration
# Obtenha sua API key em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Root Path Configuration
# Caminho da pasta raiz onde os arquivos Office estão localizados
# Exemplo Windows: C:\Users\seu_usuario\Documents
# Exemplo Linux/Mac: /home/seu_usuario/documents
ROOT_PATH=/path/to/your/office/files

# Model Configuration
# Nome do modelo Gemini principal (padrão: gemini-2.5-flash-lite)
# Modelos estáveis (GA): gemini-2.5-flash-lite (15 RPM), gemini-2.5-flash (10 RPM), gemini-2.5-pro (5 RPM)
MODEL_NAME=gemini-2.5-flash-lite

# Modelos de fallback (separados por vírgula)
# Usados automaticamente quando o modelo principal atinge rate limit
# Padrão: todos os outros modelos estáveis da família 2.5
# FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-pro

# Version Control Configuration
# Número máximo de versões a manter por arquivo (padrão: 10)
MAX_VERSIONS=10

# Cache Configuration
# Habilitar cache de respostas do Gemini (padrão: true)
CACHE_ENABLED=true

# Tempo de vida do cache em horas (padrão: 24)
CACHE_TTL_HOURS=24

# Número máximo de entradas no cache (padrão: 100)
CACHE_MAX_ENTRIES=100
